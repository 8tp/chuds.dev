---
import { site } from "~/data/site";

const tools = [
  ...site.tools.languages,
  "React",
  "Astro",
  "Ratatui",
  "SwiftUI",
  "Node.js",
  "PostgreSQL",
  "Docker",
  "Cloudflare",
  "macOS",
];
---

<section id="stack" class="border border-border bg-panel">
  <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
    <span>// tech stack</span>
    <span>{tools.length} tools</span>
  </div>
  <div class="grid grid-cols-3 sm:grid-cols-2 gap-x-3 sm:gap-x-4 gap-y-1 sm:gap-y-1.5 p-3 sm:p-4 font-mono text-[11px] sm:text-xs">
    {tools.map((tool) => (
      <span class="flex items-baseline gap-1.5">
        <span class="text-comment">·</span>
        <span>{tool}</span>
      </span>
    ))}
  </div>
</section>
