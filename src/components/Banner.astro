---
import { site } from "~/data/site";

/**
 * Hero banner — renders /banner.webp when the codex prompt has filled
 * it in. Until then, the CSS wordmark below stands in. Either way the
 * top of the page reads "chuds.dev — premium software from the basement".
 */
---

<header class="reveal mb-8">
  <div class="win" style="--win-accent: var(--color-magenta)">
    <div class="win-title">
      <span class="win-dots"><span></span><span></span><span></span></span>
      <span class="text-fg-dim">~/chuds.dev</span>
      <span class="text-comment">·</span>
      <span class="text-fg-muted">cat banner.txt</span>
    </div>

    <div class="relative">
      <!-- Generated banner — codex drops this asset in /public/banner.webp -->
      <img
        src="/banner.webp"
        alt="chuds.dev — premium software from the basement"
        width="1280"
        height="320"
        class="block w-full h-auto select-none"
        loading="eager"
        decoding="async"
        onerror="this.classList.add('hidden'); document.getElementById('banner-fallback')?.removeAttribute('hidden');"
      />

      <!-- Fallback wordmark, only shown if /banner.webp is missing -->
      <div id="banner-fallback" hidden class="px-6 sm:px-10 py-10 sm:py-14 text-center">
        <h1 class="font-display font-bold text-4xl sm:text-6xl lg:text-7xl tracking-tight">
          <span class="text-fg">chuds</span><span class="text-magenta">.dev</span>
        </h1>
        <p class="mt-3 font-mono text-xs sm:text-sm text-fg-muted">
          <span class="text-green">$</span> {site.tagline}<span class="inline-block w-2 h-4 align-[-1px] ml-1 bg-fg-dim animate-pulse"></span>
        </p>
      </div>
    </div>
  </div>
</header>
