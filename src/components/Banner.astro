---
import { site } from "~/data/site";
import { contributionLevel, formatCompact, github } from "~/data/github";

const months = ["May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec", "Jan", "Feb", "Mar", "Apr"];
const contributionCounts = new Map<string, number>(github.contributions.nonzero);
const start = new Date(`${github.contributions.start}T00:00:00Z`);
const end = new Date(`${github.contributions.end}T00:00:00Z`);
const cells: { date: string; count: number; level: number }[] = [];

for (const day = new Date(start); day <= end; day.setUTCDate(day.getUTCDate() + 1)) {
  const date = day.toISOString().slice(0, 10);
  const count = contributionCounts.get(date) ?? 0;
  cells.push({ date, count, level: contributionLevel(count) });
}
---

<header class="reveal">
  <div class="grid grid-cols-1 gap-4 min-w-0">
    <section class="win speed-lines min-h-[12rem] sm:min-h-[17rem] flex items-stretch min-w-0">
      <div class="absolute top-0 left-0 right-0 z-10 flex items-center justify-between gap-3 border-b border-border bg-fg text-panel px-3 py-1.5 font-mono text-[10px] uppercase tracking-normal">
        <span class="flex items-center gap-2">
          <span>chuds.dev mag</span>
          <span class="text-gutter">·</span>
          <span class="hidden sm:inline">vol. 2026</span>
          <span class="text-gutter hidden sm:inline">·</span>
          <span>issue 01</span>
        </span>
        <span class="flex items-center gap-2">
          <span class="hidden sm:inline">{site.author.location}</span>
          <span class="text-gutter hidden sm:inline">/</span>
          <span>p. 001</span>
        </span>
      </div>
      <div class="win-body w-full pt-8 sm:pt-10 min-w-0">
        <div class="flex flex-col lg:flex-row lg:items-end gap-4 sm:gap-6 min-w-0">
          <div class="min-w-0 flex-1">
            <p class="font-mono text-[11px] sm:text-xs font-bold mb-2 sm:mb-4">// {site.author.handle} / home</p>
            <h1 class="font-display text-[3.25rem] sm:text-[5.75rem] lg:text-[7rem] font-black leading-[0.83] tracking-normal">
              {site.title}
            </h1>
            <p class="mt-2 sm:mt-4 max-w-xl font-mono text-[13px] sm:text-base text-fg-dim">
              {site.tagline}
            </p>
          </div>
          <div class="relative border border-border bg-fg text-panel p-3 sm:p-4 self-start lg:self-auto max-w-[16rem] font-mono text-[12px] sm:text-sm leading-snug sm:leading-relaxed shadow-[4px_4px_0_var(--color-panel)]">
            <p class="absolute -top-2 left-2 bg-panel text-fg px-1 font-mono text-[10px] uppercase border border-border">
              manifesto
            </p>
            <p>code the tool.</p>
            <p>ship the game.</p>
            <p>keep it sharp.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border border-border bg-panel">
      <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
        <span>// editor's letter</span>
        <span>p. 002</span>
      </div>
      <div class="grid grid-cols-[auto_1fr] gap-3 sm:gap-4 p-3 sm:p-5">
        <div class="font-display text-[2.75rem] sm:text-[4.5rem] font-black leading-none text-fg shrink-0 self-start">
          “
        </div>
        <p class="text-[13px] sm:text-[15px] leading-snug sm:leading-relaxed text-fg-dim self-center">
          this is volume 2026, issue 01 — a dense one. five live games on the cover, a fistful
          of native macOS utilities in the back, and a couple of rust TUIs holding the centerfold.
          come for the ant, stay for the type combat.
        </p>
      </div>
    </section>

    <section class="border border-border bg-panel">
      <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
        <span>// chapter 00 / contribution rhythm</span>
        <span>github.com/8tp</span>
      </div>
      <div class="p-3 sm:p-5">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-4">
        <div>
          <h2 class="font-display text-xl font-black leading-none">365 day spread</h2>
          <p class="font-mono text-[11px] text-fg-muted mt-1">cells weight by contribution count</p>
        </div>
        <div class="grid grid-cols-3 sm:grid-cols-5 gap-x-3 gap-y-1 font-mono text-[11px]">
          <span><strong class="text-fg block text-sm">{formatCompact(github.profile.yearlyContributions)}</strong>contribs</span>
          <span><strong class="text-fg block text-sm">{github.profile.publicRepos}</strong>repos</span>
          <span><strong class="text-fg block text-sm">{github.profile.followers}</strong>followers</span>
          <span><strong class="text-fg block text-sm">{github.profile.totalStars}</strong>stars</span>
          <span><strong class="text-fg block text-sm">{github.profile.totalForks}</strong>forks</span>
        </div>
      </div>

      <div class="overflow-x-auto pb-1 max-w-full">
        <div class="w-[42rem]">
          <div class="grid grid-cols-12 gap-1 mb-1 pl-8 font-mono text-[10px] text-fg-muted">
            {months.map((month) => <span>{month}</span>)}
          </div>
          <div class="grid grid-cols-[1.75rem_1fr] gap-2">
            <div class="grid grid-rows-7 gap-1 font-mono text-[10px] text-fg-muted">
              <span></span>
              <span>Mon</span>
              <span></span>
              <span>Wed</span>
              <span></span>
              <span>Fri</span>
              <span></span>
            </div>
            <div class="grid grid-flow-col grid-rows-7 gap-1">
              {cells.map((level) => (
                <span
                  class:list={[
                    "size-2.5 border border-border/50",
                    level.level === 0 && "bg-panel",
                    level.level === 1 && "bg-gutter",
                    level.level === 2 && "bg-fg-muted",
                    level.level === 3 && "bg-fg-dim",
                    level.level === 4 && "bg-fg",
                  ]}
                  title={`${level.count} contributions on ${level.date}`}
                />
              ))}
            </div>
          </div>
        </div>
      </div>
      <p class="mt-2 font-mono text-[10px] text-fg-muted">
        snapshot: {new Date(github.generatedAt).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}
      </p>
      </div>
    </section>
  </div>
</header>
