---
import { site } from "~/data/site";

/**
 * Hero banner — renders /banner.webp directly without the surrounding
 * win-chrome wrapper, because the generated asset bakes in its own
 * traffic-light dots and "tokyonight" tag. A CSS wordmark stands in if
 * the asset is ever missing.
 */
---

<header class="reveal mb-8">
  <div
    class="relative rounded-xl overflow-hidden border border-border bg-bg-dark shadow-[0_16px_32px_-20px_rgba(0,0,0,0.6)]"
    style="--win-accent: var(--color-magenta);"
  >
    <!-- yabai-accent stripe along the top -->
    <span class="absolute inset-x-0 top-0 h-[2px] bg-magenta/70 z-10"></span>

    <img
      src="/banner.webp"
      alt="chuds.dev — premium software, engineered from the basement"
      width="1280"
      height="320"
      class="block w-full h-auto select-none"
      loading="eager"
      decoding="async"
      onerror="this.classList.add('hidden'); document.getElementById('banner-fallback')?.removeAttribute('hidden');"
    />

    <!-- Fallback wordmark, only shown if /banner.webp is missing -->
    <div
      id="banner-fallback"
      hidden
      class="px-6 sm:px-10 py-10 sm:py-14 text-center"
    >
      <h1 class="font-display font-bold text-4xl sm:text-6xl lg:text-7xl tracking-tight">
        <span class="text-fg">chuds</span><span class="text-magenta">.dev</span>
      </h1>
      <p class="mt-3 font-mono text-xs sm:text-sm text-fg-muted">
        <span class="text-green">$</span> {site.tagline}<span
          class="inline-block w-2 h-4 align-[-1px] ml-1 bg-fg-dim animate-pulse"
        ></span>
      </p>
    </div>
  </div>
</header>
