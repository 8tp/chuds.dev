---
import SectionLabel from "./SectionLabel.astro";
import { site } from "~/data/site";

/**
 * Tools — tech stack mirroring the legacy chuds.dev "Tools of the trade"
 * grid. Grouped trafficlunar-style for scannability, but the items are
 * Hunter's actual stack (TypeScript, React, Next, Tailwind, Node, Rust,
 * Go, Swift) plus the editor + infra rows.
 */
const groups = [
  { key: "editors", color: "text-yellow" },
  { key: "languages", color: "text-cyan" },
  { key: "frameworks", color: "text-magenta" },
  { key: "infra", color: "text-green" },
] as const;
---

<section class="reveal" id="tools" style="--reveal-delay: 80ms">
  <SectionLabel index="02" label="tools" cmd="ls stack/" />
  <div class="win" style="--win-accent: var(--color-magenta)">
    <div class="win-body space-y-3.5">
      {groups.map((g) => (
        <div class="grid grid-cols-[7rem_1fr] gap-2 items-start">
          <div class="font-mono text-xs pt-1">
            <span class={g.color}>{g.key}</span>
            <span class="text-comment">/</span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {site.tools[g.key].map((item) => (
              <span class="pill">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
