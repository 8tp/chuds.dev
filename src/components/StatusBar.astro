---
/**
 * Sketchybar/yabai-style top status bar.
 * Gives the page a "this is a tiling WM" identity from the first pixel.
 */
---

<div class="flex items-center justify-between gap-4 mb-6 px-3 py-1.5 rounded-md border border-border bg-bg-dark/80 backdrop-blur text-[11px] font-mono text-fg-muted">
  <div class="flex items-center gap-3">
    <span class="text-magenta">●</span>
    <span>chuds.dev</span>
    <span class="text-comment">│</span>
    <span class="hidden sm:inline">workspace 1</span>
  </div>
  <div class="hidden md:flex items-center gap-3">
    <span><span class="text-cyan">arch</span> · <span class="text-magenta">tokyonight</span></span>
    <span class="text-comment">│</span>
    <span><span class="text-green">●</span> online</span>
  </div>
  <div class="flex items-center gap-3">
    <span class="font-display tabular-nums" id="clock">--:--</span>
  </div>
</div>

<script>
  const tick = () => {
    const el = document.getElementById("clock");
    if (!el) return;
    const d = new Date();
    el.textContent = `${d.getHours().toString().padStart(2, "0")}:${d
      .getMinutes()
      .toString()
      .padStart(2, "0")}`;
  };
  tick();
  setInterval(tick, 30_000);
</script>
