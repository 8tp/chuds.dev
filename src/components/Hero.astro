---
import { site } from "~/data/site";
---

<section class="win speed-lines min-h-[12rem] sm:min-h-[17rem] flex items-stretch min-w-0">
  <div class="absolute top-0 left-0 right-0 z-10 flex items-center justify-between gap-3 border-b border-border bg-fg text-panel px-3 py-1.5 font-mono text-[10px] uppercase tracking-normal">
    <span class="flex items-center gap-2">
      <span>chuds.dev mag</span>
      <span class="text-gutter">·</span>
      <span class="hidden sm:inline">vol. 2026</span>
      <span class="text-gutter hidden sm:inline">·</span>
      <span>issue 01</span>
    </span>
    <span class="flex items-center gap-2">
      <span class="hidden sm:inline">{site.author.location}</span>
      <span class="text-gutter hidden sm:inline">/</span>
      <span>p. 001</span>
    </span>
  </div>
  <div class="win-body w-full pt-8 sm:pt-10 min-w-0">
    <div class="flex flex-col lg:flex-row lg:items-end gap-4 sm:gap-6 min-w-0">
      <div class="min-w-0 flex-1">
        <p class="font-mono text-[11px] sm:text-xs font-bold mb-2 sm:mb-4">// {site.author.handle} / home</p>
        <h1 class="font-display text-[3.25rem] sm:text-[5.75rem] lg:text-[7rem] font-black leading-[0.83] tracking-normal">
          {site.title}
        </h1>
        <p class="mt-2 sm:mt-4 max-w-xl font-mono text-[13px] sm:text-base text-fg-dim">
          {site.tagline}
        </p>
      </div>
      <div class="relative border border-border bg-fg text-panel p-3 sm:p-4 self-start lg:self-auto max-w-[16rem] font-mono text-[12px] sm:text-sm leading-snug sm:leading-relaxed shadow-[4px_4px_0_var(--color-panel)]">
        <p class="absolute -top-2 left-2 bg-panel text-fg px-1 font-mono text-[10px] uppercase border border-border">
          manifesto
        </p>
        <p>code the tool.</p>
        <p>ship the game.</p>
        <p>keep it sharp.</p>
      </div>
    </div>
  </div>
</section>
