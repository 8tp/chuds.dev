---
interface Props {
  index: string;
  label: string;
  cmd?: string;
  id?: string;
  /** Optional kanji / glyph rendered in the label badge. */
  glyph?: string;
}
const { index, label, cmd, id, glyph } = Astro.props;
---

<div class="flex items-stretch gap-2 mb-3 font-mono text-xs sm:text-sm" id={id}>
  <span class="flex items-center gap-2 border border-border bg-fg text-panel px-2 py-1 font-bold uppercase">
    <span class="opacity-70">p.</span>
    <span>{index}</span>
    {glyph && (
      <span class="border-l border-panel/30 pl-2 font-display text-[0.85rem] leading-none">
        {glyph}
      </span>
    )}
  </span>
  <span class="flex items-baseline gap-2 border border-border bg-panel px-2.5 py-1">
    <span class="text-fg font-bold">~/{label}</span>
    <span class="text-fg-muted">$</span>
    <span class="text-fg-dim hidden sm:inline">{cmd ?? `cat ${label}.md`}</span>
  </span>
  <span class="flex-1 self-center ascii-rule overflow-hidden">
    -----------------------------------------------------------
  </span>
  <span class="hidden sm:flex items-center border border-border bg-panel px-2 py-1 text-[10px] uppercase text-fg-muted">
    fold {index}
  </span>
</div>
