---
import { site } from "~/data/site";
import AvatarCard from "./AvatarCard.astro";
import TechStack from "./TechStack.astro";

const sections = [
  { label: "about", href: "#about" },
  { label: "projects", href: "#projects" },
  { label: "stack", href: "#stack" },
];
---

<aside class="sidebar-rail hidden lg:flex lg:sticky lg:top-8 lg:max-h-[calc(100vh-4rem)] lg:overflow-y-auto flex-col gap-5 pr-1 [&>*]:shrink-0">
  <div class="relative flex min-h-[34rem] border border-border bg-panel overflow-hidden">
    <a
      href="/"
      aria-label="chuds.dev home"
      class="group relative flex w-full items-center justify-center bg-panel"
    >
      <span class="absolute top-3 left-3 font-mono text-[10px] font-bold uppercase tracking-normal">
        // {site.author.handle}
      </span>
      <span class="absolute top-3 right-3 font-mono text-[10px] uppercase tracking-normal text-fg-muted">
        spine
      </span>
      <span class="absolute bottom-3 left-3 flex flex-col gap-0.5 font-mono text-[10px] uppercase tracking-normal text-fg-muted leading-tight">
        <span class="text-fg font-bold">vol. 2026</span>
        <span>issue 01</span>
      </span>
      <span class="absolute bottom-3 right-3 font-mono text-[10px] uppercase tracking-normal text-fg-muted [writing-mode:vertical-rl]">
        manga edition
      </span>
      <span class="font-display text-[5.75rem] font-black leading-none tracking-normal [writing-mode:vertical-rl] rotate-180 group-hover:translate-x-[-2px] transition-transform">
        {site.title}
      </span>
    </a>
  </div>

  <AvatarCard />

  <nav class="border border-border bg-panel" aria-label="Sections">
    <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
      <span>// table of contents</span>
      <span>toc</span>
    </div>
    <div class="flex flex-col font-mono text-xs">
      {sections.map((item, index) => (
        <a
          href={item.href}
          class="flex items-center justify-between border-b border-border px-3 py-2 last:border-b-0 hover:bg-fg hover:text-panel transition-colors"
        >
          <span>// {String(index + 1).padStart(2, "0")}</span>
          <span>/{item.label}</span>
          <span class="text-fg-muted text-[10px]">p. {String(index + 1).padStart(2, "0")}</span>
        </a>
      ))}
    </div>
  </nav>

  <TechStack />

  <div class="aspect-[4/3] border border-border bg-panel">
    <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
      <span>// scene 01</span>
      <span>workspace</span>
    </div>
    <div class="relative h-[calc(100%-1.6rem)] overflow-hidden bg-bg-dark">
      <img
        src="/manga-workspace.png"
        alt="Black-and-white manga illustration of a developer workspace"
        width="1000"
        height="750"
        class="size-full object-cover grayscale contrast-125 mix-blend-multiply"
        loading="lazy"
        decoding="async"
      />
      <p class="absolute bottom-1 left-1 bg-fg text-panel px-1.5 py-0.5 font-mono text-[9px] uppercase">
        basement HQ
      </p>
    </div>
  </div>
</aside>
