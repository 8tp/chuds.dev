---
import { site } from "~/data/site";
import { formatCompact, github } from "~/data/github";
---

<section class="win">
  <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
    <span>// cover star</span>
    <span class="text-gutter">no. {String(github.profile.publicRepos).padStart(2, "0")}</span>
  </div>
  <div class="relative aspect-[16/10] sm:aspect-[4/3] overflow-hidden border-b border-border screentone">
    <img
      src="https://avatars.githubusercontent.com/u/79799382?s=512&v=4"
      alt={site.author.name}
      width="512"
      height="512"
      class="size-full object-cover object-top grayscale contrast-125 mix-blend-multiply"
      loading="eager"
      decoding="async"
    />
    <span class="absolute bottom-2 right-2 bg-fg text-panel px-1.5 py-0.5 font-mono text-[9px] uppercase">
      @{site.author.handle}
    </span>
  </div>
  <div class="bg-fg text-panel px-3 sm:px-4 py-2 sm:py-3">
    <p class="font-display text-xl sm:text-2xl font-black leading-none">{site.author.name}</p>
    <p class="font-mono text-[11px] mt-0.5 sm:mt-1 text-gutter">{site.author.pronouns} · {site.author.location}</p>
  </div>
  <div class="px-3 sm:px-4 py-2.5 sm:py-3 space-y-2.5 sm:space-y-3 text-sm leading-relaxed">
    <p class="font-mono text-[12px] hidden sm:block">
      premium software,<br />engineered from the basement
    </p>
    <div class="grid grid-cols-4 sm:grid-cols-2 gap-y-1 sm:gap-y-1.5 gap-x-2 sm:border-t sm:border-border sm:pt-3 font-mono text-[10px] sm:text-[11px]">
      <span><strong class="text-fg">{github.profile.publicRepos}</strong> repos</span>
      <span><strong class="text-fg">{github.profile.followers}</strong> followers</span>
      <span><strong class="text-fg">{formatCompact(github.profile.yearlyContributions)}</strong> contribs</span>
      <span><strong class="text-fg">{github.profile.totalStars}</strong> stars</span>
    </div>
    <a
      href="https://github.com/8tp"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-between border border-border bg-panel px-3 py-2 font-mono text-xs font-bold hover:bg-fg hover:text-panel transition-colors"
    >
      <span>GitHub</span>
      <span>github.com/8tp -&gt;</span>
    </a>
  </div>
</section>
