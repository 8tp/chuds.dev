---
import { contributionLevel, formatCompact, github } from "~/data/github";

const months = ["May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec", "Jan", "Feb", "Mar", "Apr"];
const contributionCounts = new Map<string, number>(github.contributions.nonzero);
const start = new Date(`${github.contributions.start}T00:00:00Z`);
const end = new Date(`${github.contributions.end}T00:00:00Z`);
const cells: { date: string; count: number; level: number }[] = [];

for (const day = new Date(start); day <= end; day.setUTCDate(day.getUTCDate() + 1)) {
  const date = day.toISOString().slice(0, 10);
  const count = contributionCounts.get(date) ?? 0;
  cells.push({ date, count, level: contributionLevel(count) });
}
---

<section class="border border-border bg-panel">
  <div class="flex items-center justify-between border-b border-border bg-fg text-panel px-3 py-1 font-mono text-[10px] uppercase">
    <span>// chapter 00 / contribution rhythm</span>
    <span>github.com/8tp</span>
  </div>
  <div class="p-3 sm:p-5">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-4">
      <div>
        <h2 class="font-display text-xl font-black leading-none">365 day spread</h2>
        <p class="font-mono text-[11px] text-fg-muted mt-1">cells weight by contribution count</p>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-x-3 gap-y-1 font-mono text-[11px]">
        <span><strong class="text-fg block text-sm">{formatCompact(github.profile.yearlyContributions)}</strong>contribs</span>
        <span><strong class="text-fg block text-sm">{github.profile.publicRepos}</strong>repos</span>
        <span><strong class="text-fg block text-sm">{github.profile.followers}</strong>followers</span>
        <span><strong class="text-fg block text-sm">{github.profile.totalStars}</strong>stars</span>
        <span><strong class="text-fg block text-sm">{github.profile.totalForks}</strong>forks</span>
      </div>
    </div>

    <div class="overflow-x-auto pb-1 max-w-full" data-scroll-end>
      <div class="w-[42rem]">
        <div class="grid grid-cols-12 gap-1 mb-1 pl-8 font-mono text-[10px] text-fg-muted">
          {months.map((month) => <span>{month}</span>)}
        </div>
        <div class="grid grid-cols-[1.75rem_1fr] gap-2">
          <div class="grid grid-rows-7 gap-1 font-mono text-[10px] text-fg-muted">
            <span></span>
            <span>Mon</span>
            <span></span>
            <span>Wed</span>
            <span></span>
            <span>Fri</span>
            <span></span>
          </div>
          <div class="grid grid-flow-col grid-rows-7 gap-1">
            {cells.map((level) => (
              <span
                class:list={[
                  "size-2.5 border border-border/50",
                  level.level === 0 && "bg-panel",
                  level.level === 1 && "bg-gutter",
                  level.level === 2 && "bg-fg-muted",
                  level.level === 3 && "bg-fg-dim",
                  level.level === 4 && "bg-fg",
                ]}
                title={`${level.count} contributions on ${level.date}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
    <p class="mt-2 font-mono text-[10px] text-fg-muted">
      snapshot: {new Date(github.generatedAt).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}
    </p>
  </div>
</section>

<script>
  // Park the heatmap scroll at its right edge so the most-recent days
  // are visible by default on narrow screens (where the strip overflows).
  for (const el of document.querySelectorAll<HTMLElement>("[data-scroll-end]")) {
    el.scrollLeft = el.scrollWidth;
  }
</script>
