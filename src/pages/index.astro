---
import Layout from "~/layouts/Layout.astro";
import Sidebar from "~/components/Sidebar.astro";
import About from "~/components/About.astro";
import Tools from "~/components/Tools.astro";
import Projects from "~/components/Projects.astro";
---

<Layout>
  <div class="grid grid-cols-1 lg:grid-cols-[14rem_1fr] gap-8 lg:gap-12">
    <Sidebar />

    <div class="flex flex-col gap-8 sm:gap-10">
      <About />
      <Tools />
      <Projects />

      <footer class="pt-6 mt-4 border-t border-surface0/60 text-xs text-overlay0 font-mono">
        <div class="flex flex-col sm:flex-row justify-between gap-2">
          <span>© {new Date().getFullYear()} chuds.dev — built with Astro + Svelte</span>
          <a
            href="https://github.com/8tp/chuds.dev"
            target="_blank"
            rel="noopener"
            class="hover:text-peach transition-colors"
          >
            view source ↗
          </a>
        </div>
      </footer>
    </div>
  </div>
</Layout>
